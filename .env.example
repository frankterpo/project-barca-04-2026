# --- M1: App (scaffold) ---
APP_URL=http://localhost:3000
# Optional: override default JSON run id (default: demo-v1)
# LOBSTER_DEFAULT_RUN_ID=demo-v1
# NEXT_PUBLIC_LOBSTER_DEFAULT_RUN_ID=demo-v1

# --- M2: Cala (knowledge API — https://docs.cala.ai) ---
# Required — all Cala routes fail fast without these two:
# CALA_API_KEY=
# CALA_TEAM_ID=
# Optional — defaults to https://api.cala.ai
# CALA_BASE_URL=
# Optional — leaderboard JSON (non-empty array of rows). Can be full /api/leaderboard URL or dashboard origin (we also try origin/api/leaderboard).
# CALA_LEADERBOARD_URL=https://different-cormorant-663.convex.site/api/leaderboard
# Optional — extra bases to try, comma- or space-separated (404/HTML on one host is common).
# CALA_LEADERBOARD_URLS=
# Optional — submit URL; we also try {origin}/api/leaderboard from this URL when leaderboard env is missing or fails.
# CALA_SUBMIT_URL=https://different-cormorant-663.convex.site/api/submit
# Optional — Convex dashboard query endpoint (POST /api/query). If unset, derived from CALA_SUBMIT_URL host (.site → .cloud).
# CALA_CONVEX_QUERY_URL=https://different-cormorant-663.convex.cloud/api/query
# Live submits (price-harvester --optimize without --dry-run, autonomous-runner): set only when you intentionally want POSTs.
# CALA_ALLOW_SUBMIT=

# --- M3: Omnigraph (open-source context graph — https://omnigraph.dev) ---
# Optional — defaults to http://127.0.0.1:8080
# OMNIGRAPH_URL=
# Optional — only needed for shared/remote deployments
# OMNIGRAPH_BEARER_TOKEN=

# --- M4: Northflank (compute / jobs — https://northflank.com/docs/v1/api) ---
# Required — all /api/compute/* routes fail fast without this:
# NORTHFLANK_API_KEY=
