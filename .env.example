# --- M1: App (scaffold) ---
APP_URL=http://localhost:3000
# Optional: override default JSON run id (default: demo-v1)
# LOBSTER_DEFAULT_RUN_ID=demo-v1
# NEXT_PUBLIC_LOBSTER_DEFAULT_RUN_ID=demo-v1

# --- M2: Cala (knowledge API — https://docs.cala.ai) ---
# Required — all Cala routes fail fast without these two:
# CALA_API_KEY=
# CALA_TEAM_ID=
# Optional — defaults to https://api.cala.ai
# CALA_BASE_URL=
# Optional — leaderboard JSON (non-empty array of rows). Can be full /api/leaderboard URL or dashboard origin (we also try origin/api/leaderboard).
# CALA_LEADERBOARD_URL=https://different-cormorant-663.convex.site/api/leaderboard
# Optional — extra bases to try, comma- or space-separated (404/HTML on one host is common).
# CALA_LEADERBOARD_URLS=
# Optional — submit URL; we also try {origin}/api/leaderboard from this URL when leaderboard env is missing or fails.
# CALA_SUBMIT_URL=https://different-cormorant-663.convex.site/api/submit
# Optional — Convex dashboard query endpoint (POST /api/query). If unset, derived from CALA_SUBMIT_URL host (.site → .cloud).
# CALA_CONVEX_QUERY_URL=https://different-cormorant-663.convex.cloud/api/query
# Live submits (price-harvester --optimize without --dry-run, autonomous-runner): set only when you intentionally want POSTs.
# CALA_ALLOW_SUBMIT=
# Optional — leaderboard team slug for gap benchmark in logs / --leaderboard (default: sourish).
# CALA_BENCHMARK_TEAM_ID=sourish

# Price harvester (`scripts/price-harvester.ts`): universe + batch controls
# CALA_EXTRA_TICKERS=SYM1,SYM2
# Optional — merge JSON candidate lists (comma-separated paths under repo root). Default also merges data/research-harvest-candidates.json when present unless:
# CALA_MERGE_RESEARCH_CANDIDATES=0
# CALA_HARVEST_CANDIDATE_FILES=data/custom-candidates.json
# Limit harvest waves (0 = all): CALA_HARVEST_MAX_BATCHES=3
# Warn if data/price-db.json older than N hours (0 = off): CALA_PRICE_DB_WARN_STALE_HOURS=48

# Supabase Postgres (optional) — `runs`, `run_holdings`, `prices` via direct connection.
# Dashboard → Project Settings → Database → Connection string (pooler, URI).
# When set, price-harvester / research-agent append rows to `runs`; harvest + optimize upsert `prices`;
# successful `--optimize` submits also insert `run_holdings`. Disable with CALA_SUPABASE_SYNC=0.
# SUPABASE_CONNECTION=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# CALA_SUPABASE_SYNC=
#
# Portfolio stats on `/portfolio`: by default tickers in `bad_tickers` are excluded from green/red counts (actionable view).
# Set to 1 to include every row (audit / legacy).
# PORTFOLIO_INCLUDE_BAD_TICKERS=
# Deep-loser quarantine threshold for `pnpm quarantine:losers` (default -85). Override per run: `--threshold=-90`.
# CALA_QUARANTINE_RETURN_PCT=-85

# --- M3: Omnigraph (open-source context graph — https://omnigraph.dev) ---
# Optional — defaults to http://127.0.0.1:8080
# OMNIGRAPH_URL=
# Optional — only needed for shared/remote deployments
# OMNIGRAPH_BEARER_TOKEN=

# --- M4: Northflank (compute / jobs — https://northflank.com/docs/v1/api) ---
# Required — all /api/compute/* routes fail fast without this:
# NORTHFLANK_API_KEY=
# Optional — for scripts/trigger-research-job.ts (pnpm agent:run-remote):
# NORTHFLANK_PROJECT_ID=
# NORTHFLANK_RESEARCH_JOB_ID=
# Legacy alias: NORTHFLANK_JOB_ID=
# NORTHFLANK_POLL_MS=8000
# NORTHFLANK_MAX_WAIT_MS=3600000
# Optional — docker compose under northflank/omnigraph.docker-compose.yaml
# OMNIGRAPH_DOCKER_IMAGE=ghcr.io/modernrelay/omnigraph-server:latest
